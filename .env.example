# .env.example

# Relay
RELAY_DATABASE_URL=postgresql://mystere:devpassword@localhost:5432/mystere_relay
RELAY_REDIS_URL=redis://localhost:6379/0
RELAY_HOST=0.0.0.0
RELAY_PORT=8000
RELAY_WEBAUTHN_RP_ID=localhost
RELAY_PREKEY_REPLENISH_THRESHOLD=20
RELAY_MESSAGE_QUEUE_TTL_HOURS=72

# Custodian
CUSTODIAN_DATABASE_URL=postgresql://mystere:devpassword@localhost:5433/mystere_custodian
CUSTODIAN_REDIS_URL=redis://localhost:6379/1
CUSTODIAN_HOST=0.0.0.0
CUSTODIAN_PORT=8001
CUSTODIAN_WEBAUTHN_RP_ID=localhost
CUSTODIAN_CLEANUP_INTERVAL_SECONDS=60
CUSTODIAN_MAX_BLOB_SIZE_BYTES=256
CUSTODIAN_MAX_TTL_SECONDS=7200

# Client
VITE_RELAY_URL=wss://localhost:8000/ws
VITE_RELAY_API=https://localhost:8000
VITE_WEBAUTHN_RP_ID=localhost

# Crypto parameters
BASE_ROTATION_N=50
JITTER_K_MAX=20
DRIFT_WINDOW_K_MAX=5
GRACE_WINDOW_SECONDS=30
FRAGMENT_BATCH_SIZE=8
PAD_BLOCK_SIZE=256
CHECKPOINT_INTERVAL=25
RETRY_THRESHOLD=5
